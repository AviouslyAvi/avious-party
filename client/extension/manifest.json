{
  "manifest_version": 3,
  "name": "Watch-Party",
  "version": "0.4.0",
  "description": "Teleparty-style synchronized watch party for any site with a video player.",
  "permissions": ["storage", "notifications", "tabs"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle",
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Watch-Party",
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/fonts/*",
        "styles/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
